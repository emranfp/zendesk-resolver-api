PORT=3000
NODE_ENV=development
INTERNAL_API_KEY=change_me

# Blockchain APIs
ETHERSCAN_API_KEY=your_etherscan_key
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# HTTP retry tuning
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_MS=300
ZENDESK_RETRY_MAX_ATTEMPTS=3
ZENDESK_RETRY_BASE_DELAY_MS=300

# Zendesk (optional; when omitted, Zendesk updates are skipped)
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
